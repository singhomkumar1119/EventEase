@page "/registration"
@inject EventRepository Repo
@inject UserSessionService Session

<PageTitle>Register</PageTitle>

<h1>Event Registration</h1>

<EditForm Model="@attendee" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="form-field">
        <label>Full Name</label>
        <InputText @bind-Value="attendee.FullName" />
        <ValidationMessage For="@(() => attendee.FullName)" />
    </div>

    <div class="form-field">
        <label>Email</label>
        <InputText @bind-Value="attendee.Email" />
        <ValidationMessage For="@(() => attendee.Email)" />
    </div>

    <div class="form-field">
        <label>Event</label>
        <InputSelect @bind-Value="attendee.EventId">
            <option value="0">-- Select an event --</option>
            @foreach (var ev in Repo.GetAll())
            {
                <option value="@ev.Id">@ev.Name (@ev.Date.ToShortDateString())</option>
            }
        </InputSelect>
        <ValidationMessage For="@(() => attendee.EventId)" />
    </div>

    <button type="submit" class="btn btn-primary">Register</button>
</EditForm>

@if (submitted)
{
    <p class="alert alert-success">
        Thanks, @attendee.FullName! You're registered for
        @(Repo.GetById(attendee.EventId)?.Name ?? "the event").
    </p>
}

@code {
    private Attendee attendee = new();
    private bool submitted = false;

    private void HandleValidSubmit()
    {
        // Extra validation beyond DataAnnotations: make sure an event was
        // actually picked (0 is technically a valid int, so [Required] alone
        // won't catch it) — closes a bug found while debugging Activity 2.
        if (attendee.EventId == 0)
        {
            return;
        }

        Repo.IncrementRegistration(attendee.EventId);
        Session.AddRegistration(attendee);
        submitted = true;

        // Reset the form for the next entry while keeping the confirmation visible.
        attendee = new Attendee();
    }
}
