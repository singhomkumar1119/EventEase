<Router AppAssembly="typeof(Program).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)" />
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
    <NotFound>
        <!--
            Bug fix (Activity 2): originally navigating to an unknown route (e.g. /evnts
            typo) rendered a blank white page with no layout. Wrapping the fallback in the
            MainLayout so the nav bar stays visible and the user can recover.
        -->
        <LayoutView Layout="typeof(Layout.MainLayout)">
            <div class="alert alert-warning" role="alert">
                <h1>404 - Page not found</h1>
                <p>Sorry, we couldn't find the page you were looking for.</p>
                <a href="/">Go back to Home</a>
            </div>
        </LayoutView>
    </NotFound>
</Router>
